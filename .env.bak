#Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# When SESSION_DOMAIN is null, the cookie stays locked to the exact host (e.g., admin.duka.test).
# It won't be sent to delivery.duka.test.

#SESSION_DOMAIN=.duka.test
SESSION_DOMAIN=null

SESSION_SECURE_COOKIE=false
SESSION_COOKIE=duka_session_dev
SESSION_SAME_SITE=lax
